rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    match /mobiles/{mobile} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    match /users/{userId} {
      // Any signed-in user may read all user docs (required for the public
      // leaderboard / top-earners which list every registered fan).
      // Writes remain restricted to the owner of the document.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}